{
    "defaults": {
      "chromeLaunchConfig": {
            "ignoreHTTPSErrors": true
        },
      "reporters": [
        [
          "pa11y-ci-reporter-html",
          { "destination": "./pa11y-reports", "includeZeroIssues": true }
        ],
        "cli"
      ],
      
      "runners": ["axe", "htmlcs"],
      "includeNotices": false,
      "includeWarnings": true,
      "standard": "WCAG2AA"
    },
